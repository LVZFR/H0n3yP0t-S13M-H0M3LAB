<!--
  Cowrie honeypot detection rules for Wazuh.
  Location on the manager: /var/ossec/etc/rules/local_rules.xml
  Cowrie JSON is decoded natively by Wazuh's built-in `json` decoder
  (the agent reads the log with <log_format>json</log_format>), so no
  custom decoder is required — rules match on the decoded fields directly.
-->

<group name="cowrie,honeypot,">

  <!-- 100100: single failed login — low severity, feeds the brute-force rule -->
  <rule id="100100" level="5">
    <decoded_as>json</decoded_as>
    <field name="eventid">cowrie.login.failed</field>
    <description>Cowrie: failed login attempt ($(username)/$(password)) from $(src_ip)</description>
    <mitre><id>T1110</id></mitre>
  </rule>

  <!-- 100101: 6+ failed logins from the same source within 120s -->
  <rule id="100101" level="10" frequency="6" timeframe="120">
    <if_matched_sid>100100</if_matched_sid>
    <same_field>src_ip</same_field>
    <description>Cowrie: brute-force burst from $(src_ip) (T1110)</description>
    <mitre><id>T1110</id></mitre>
  </rule>

  <!-- 100102: successful login into the honeypot — the headline event -->
  <rule id="100102" level="12">
    <decoded_as>json</decoded_as>
    <field name="eventid">cowrie.login.success</field>
    <description>Cowrie: attacker logged in ($(username)/$(password)) from $(src_ip) (T1078)</description>
    <mitre><id>T1078</id></mitre>
  </rule>

  <!-- 100103: post-login command typed in the fake shell -->
  <rule id="100103" level="6">
    <decoded_as>json</decoded_as>
    <field name="eventid">cowrie.command.input</field>
    <description>Cowrie: command executed in honeypot shell: $(input)</description>
    <mitre><id>T1059</id></mitre>
  </rule>

  <!-- 100104 (optional): attacker pulled a file into the sandbox -->
  <rule id="100104" level="10">
    <decoded_as>json</decoded_as>
    <field name="eventid">cowrie.session.file_download</field>
    <description>Cowrie: file download in honeypot session (T1105)</description>
    <mitre><id>T1105</id></mitre>
  </rule>

</group>
